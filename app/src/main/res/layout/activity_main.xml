<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".MainActivity">

    <!-- Шапка приложения -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Главное меню"
        app:titleTextColor="@color/onPrimary"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/headerImage"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:src="@drawable/ic_app_logo"
        android:scaleType="fitCenter"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/primary" />

    <!-- Контейнер с кнопками (теперь привязан к изображению) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/headerImage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


    <!-- Кнопка "Обучение" -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLearning1"
            style="@style/Widget.Material3.Button.TonalButton"
            android:background="@drawable/button_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Обучение"
            android:textAlignment="center"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:icon="@drawable/ic_learning"
            app:iconGravity="start"
            app:iconPadding="16dp"
            app:iconTint="@color/primary"
            tools:ignore="DuplicateIds,RtlCompat" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLearning2"
            style="@style/Widget.Material3.Button.TonalButton"
            android:background="@drawable/button_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Тестирование"
            android:textAlignment="center"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:icon="@drawable/ic_testing"
            app:iconGravity="start"
            app:iconPadding="16dp"
            app:iconTint="@color/primary"
            tools:ignore="DuplicateIds,RtlCompat" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLearning3"
            style="@style/Widget.Material3.Button.TonalButton"
            android:background="@drawable/button_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Результаты"
            android:textAlignment="center"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:icon="@drawable/ic_results"
            app:iconGravity="start"
            app:iconPadding="16dp"
            app:iconTint="@color/primary"
            tools:ignore="DuplicateIds,RtlCompat" />


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
